import mlflow
import mlflow.spark
from pyspark.ml.evaluation import ClusteringEvaluator
from pyspark.sql import functions as F
from mlflow.tracking import MlflowClient

client = MlflowClient()
model_name = "workspace.default.kmeans_broadcast_model"

# Obter uma versão específica
model_version = client.get_model_version(model_name, "19")
run = client.get_run(model_version.run_id)
print(f"Versão: {model_version.version}, Run ID: {model_version.run_id}")
print(f"  SSE: {run.data.metrics.get('sse')}")
print(f"  K: {run.data.params.get('k')}")

# Carregar modelo
model_uri = f"models:/{model_name}/{model_version.version}"
model = mlflow.spark.load_model(model_uri)

# Carregar dados e garantir o cast de tipos
dados_originais = spark.table("workspace.default.broadcast_silver")
dados_para_predicao = dados_originais.dropna(subset=["Duration", "ProgramClassID"])

# Aplicar o modelo
resultados = model.transform(dados_para_predicao)

# Calcular silhouette
evaluator = ClusteringEvaluator(featuresCol="features", predictionCol="prediction", metricName="silhouette", distanceMeasure="squaredEuclidean")
silhouette = evaluator.evaluate(resultados)
print(f"Silhouette: {silhouette}")

# Medidas descritivas dos clusters
cluster_stats = resultados.groupBy("prediction").agg(
    F.count("*").alias("total_programas"),
    F.avg("Duration").alias("media_duracao_seg"),
    (F.avg("Duration")/60).alias("media_duracao_min"),
    F.stddev("Duration").alias("std_duracao"),
    F.min("Duration").alias("min_duracao"),
    F.max("Duration").alias("max_duracao"),
    F.countDistinct("ProgramClassID").alias("programas_unicos"),
    F.slice(F.collect_set("ProgramClassID"), 1, 5).alias("exemplos_programas")
).orderBy("prediction")

display(cluster_stats)
